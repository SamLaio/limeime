<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/db_manager_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="16dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:maxWidth="560dp"
        android:layout_gravity="center_horizontal">

        <!-- Heading -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_db_manager"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:paddingTop="8dp"
            android:paddingBottom="16dp" />

        <!-- Backup section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_im_backup_local"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDbBackup"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            app:cornerRadius="10dp"
            app:backgroundTint="@color/setup_status_bg"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/l3_initial_backup_database"
            android:textAllCaps="false"
            android:textColor="?attr/colorPrimary"
            app:icon="@drawable/ic_upload_24"
            app:iconTint="?attr/colorPrimary"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
 />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ui_fragment_db_manager_text_001"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp" />

        <!-- Restore section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_im_restore_local"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDbRestore"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            app:cornerRadius="10dp"
            app:backgroundTint="@color/setup_status_bg"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/l3_initial_restore_database"
            android:textAllCaps="false"
            android:textColor="@color/setup_status_fg_red"
            app:icon="@drawable/ic_download_24"
            app:iconTint="@color/setup_status_fg_red"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
 />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ui_fragment_db_manager_text_002"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp" />

        <!-- Restore default section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/l3_tab_initial"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDbRestoreDefault"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            app:cornerRadius="10dp"
            app:backgroundTint="@color/setup_status_bg"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/ui_fragment_db_manager_text_003"
            android:textAllCaps="false"
            android:textColor="@color/setup_status_fg_red"
            app:icon="@drawable/ic_refresh"
            app:iconTint="@color/setup_status_fg_red"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
 />

        <!-- Status section (hidden when empty) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/dbStatusCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/setup_status_bg"
            app:cardCornerRadius="10dp">

            <TextView
                android:id="@+id/dbStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:textAppearance="?attr/textAppearanceBody2" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
